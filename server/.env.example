# Backend Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to GitHub (it contains secrets)

# ============================================================================
# REQUIRED: Supabase Configuration
# ============================================================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# REQUIRED: Authentication
# ============================================================================
JWT_SECRET=your-secret-key-change-in-production
# Optional: Access token lifetime (default: 90m). Examples: 30m, 90m, 2h
# JWT_EXPIRY=90m
# Optional: Max session length from first login - no refresh after this (default: 90m)
# JWT_MAX_AGE=90m

# ============================================================================
# RECOMMENDED: Server Configuration
# ============================================================================
NODE_ENV=production
PORT=3001
APP_URL=https://your-frontend-url.com

# ============================================================================
# OPTIONAL: Email Configuration (SendGrid API - Recommended)
# ============================================================================
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# ============================================================================
# OPTIONAL: SMTP Configuration (Fallback)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ============================================================================
# OPTIONAL: Zoho Integration
# ============================================================================
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
# Zoho callback URL - must match EXACTLY what is in Zoho Developer Console.
# For production (Netlify + Railway): use your BACKEND URL, e.g.:
#   ZOHO_REDIRECT_URI=https://your-railway-app.up.railway.app/api/zoho/callback
# For local: http://localhost:3001/api/zoho/callback
ZOHO_REDIRECT_URI=https://your-backend-url.com/api/zoho/callback
ZOHO_REGION=com

# ============================================================================
# OPTIONAL: Daftra invoice PDF download
# ============================================================================
# Set to false to skip fetching remote PDF from Daftra (use local generator only).
# DAFTRA_USE_REMOTE_PDF=true
# Verbose Daftra API request/response logging (redacts apikey in logs)
# DAFTRA_DEBUG_API=1
